{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🛠 启动开发",
      "type": "shell",
      "command": "npx",
      "args": ["tauri", "dev"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "detail": "启动 Tauri 开发模式（Vite HMR + Rust），默认 Ctrl+Shift+B"
    },
    {
      "label": "📦 打包便携 EXE",
      "type": "shell",
      "command": "npx",
      "args": ["tauri", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$rustc"],
      "group": "build",
      "detail": "编译为便携绿色单文件 → src-tauri/target/release/app.exe"
    },
    {
      "label": "📂 打开输出目录",
      "type": "shell",
      "command": "explorer",
      "args": ["${workspaceFolder}\\src-tauri\\target\\release"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "detail": "打开 app.exe 所在目录"
    }
  ]
}
