{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "bumpLevel",
      "type": "pickString",
      "description": "版本升级类型",
      "options": ["patch", "minor", "major"],
      "default": "patch"
    },
  ],
  "tasks": [
    {
      "label": "🛠 启动开发",
      "type": "shell",
      "command": "${workspaceFolder}\\运行.bat",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$rustc"],
      "group": { "kind": "build", "isDefault": true },
      "isBackground": true,
      "detail": "启动 Tauri 开发模式 (Ctrl+Shift+B)"
    },
    {
      "label": "📦 打包发布 ZIP",
      "type": "shell",
      "command": "${workspaceFolder}\\打包.bat",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$rustc"],
      "group": "build",
      "detail": "编译 + 打包 runtime 目录为 DragonTranslator.zip"
    },
    {
      "label": "⬆️ 推送至 GitHub",
      "type": "shell",
      "command": "git push origin master",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "detail": "推送本地 commit 到 GitHub"
    },
    {
      "label": "🏷️ 发布 Release",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File release.ps1 -Bump ${input:bumpLevel}",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "detail": "自动升版本号 → 检测 ZIP → 打包 → Tag → push"
    },
    },
    {
      "label": "📂 打开输出目录",
      "type": "shell",
      "command": "explorer",
      "args": ["${workspaceFolder}\\src-tauri\\target\\release"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "detail": "打开 release 输出目录"
    }
  ]
}
