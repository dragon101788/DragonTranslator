[package]
name = "龙腾翻译"
version = "0.1.1"
description = "龙腾翻译 - 桌面翻译软件"
authors = ["Dragon"]
license = "MIT"
repository = ""
edition = "2021"
rust-version = "0.1.1"

# See more keys and their definitions at https://doc.rust-lang.org/cargo/reference/manifest.html

[lib]
name = "app_lib"
crate-type = ["staticlib", "cdylib", "rlib"]

[build-dependencies]
tauri-build = { version = "0.1.1", features = [] }

[dependencies]
serde_json = "1.0"
serde = { version = "0.1.1", features = ["derive"] }
log = "0.4"
tauri = { version = "0.1.1", features = ["tray-icon"] }
tauri-plugin-log = "2"
tauri-plugin-store = "2"
tauri-plugin-global-shortcut = "2"
zip = "2"
rodio = "0.19"
ureq = { version = "0.1.1", features = ["tls"] }
