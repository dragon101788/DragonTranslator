{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "龙腾翻译",
  "version": "0.6.9",
  "identifier": "com.dragontec.translator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5157",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "龙腾翻译",
        "label": "main",
        "width": 860,
        "height": 620,
        "minWidth": 600,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {}
}
